{
  "name": "ai-podcast-tutor",
  "version": "0.1.0",
  "private": true,
  "description": "Interactive podcast tutor — upload a doc, generate a two-host podcast, ask grounded questions.",
  "scripts": {
    "dev:api": "pnpm --filter @apt/api start:dev",
    "dev:web": "pnpm --filter @apt/web dev",
    "dev": "pnpm -r --parallel --filter \"./apps/*\" run dev",
    "build": "pnpm -r run build",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f"
  },
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20"
  }
}
