# ---------- API ----------
NODE_ENV=development
API_PORT=3001
API_BASE_URL=http://localhost:3001

# ---------- Postgres ----------
DATABASE_URL=postgresql://apt:apt@localhost:5432/apt

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379

# ---------- Qdrant ----------
QDRANT_URL=http://localhost:7333
QDRANT_COLLECTION=document_chunks

# ---------- OpenAI ----------
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE_HOST_A=alloy
OPENAI_TTS_VOICE_HOST_B=onyx

# ---------- Storage ----------
# Path is resolved from the API's cwd (apps/api), so this points to the
# project-root /storage directory.
STORAGE_DIR=../../storage

# ---------- Web ----------
VITE_API_BASE_URL=http://localhost:3001
